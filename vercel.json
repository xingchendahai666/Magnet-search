{
  "version": 2,
  "name": "magnet-search",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/build",
  "installCommand": "npm install && cd client && npm install",
  "framework": "create-react-app",
  
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
